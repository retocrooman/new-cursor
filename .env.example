# Application
APP_ENV=development

# Database (docker compose postgres — persistent volume on port 5432)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/new_cursor

# ElasticMQ (local SQS-compatible — docker compose)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=x
AWS_SECRET_ACCESS_KEY=x
SQS_ENDPOINT=http://localhost:9324
SQS_QUEUE_URL=http://localhost:9324/000000000000/dev-queue

# better-auth (apps/web)
BETTER_AUTH_SECRET=dev-only-change-me-to-at-least-32-chars!!
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Host apps (worker / relay)
WORKER_PORT=3001
RELAY_PORT=3002

# Dev seed (pnpm seed:admin — dev only)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_NAME=Admin
SEED_ADMIN_ROLE=admin
ADMIN_PASSWORD=adminpass123
