# Application
APP_ENV=development

# Database (docker compose postgres — persistent volume on port 5432)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/new_cursor

# ElasticMQ (local SQS-compatible — docker compose)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=x
AWS_SECRET_ACCESS_KEY=x
SQS_ENDPOINT=http://localhost:9324
SQS_QUEUE_URL=http://localhost:9324/000000000000/dev-queue
