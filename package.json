{
  "name": "new-cursor",
  "private": true,
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo clean",
    "dev": "turbo dev --parallel",
    "format": "biome check --write --unsafe",
    "lint": "biome check",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "pnpm --filter @new-cursor/e2e test:e2e",
    "setup:env": "pnpm --filter @new-cursor/scripts setup:env",
    "seed:admin": "pnpm --filter @new-cursor/scripts seed:admin",
    "seed:all-label": "pnpm --filter @new-cursor/scripts seed:all-label",
    "db:push": "pnpm --filter @new-cursor/db db:push"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.6",
    "@dotenvx/dotenvx": "^1.34.0",
    "lefthook": "^1.12.2",
    "tsx": "^4.7.1",
    "turbo": "^2.5.5",
    "typescript": "~5.8.3",
    "vitest": "^3.2.4"
  }
}
