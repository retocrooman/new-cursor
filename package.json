{
  "name": "new-cursor",
  "private": true,
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo clean",
    "format": "biome check --write --unsafe",
    "lint": "biome check",
    "typecheck": "turbo typecheck",
    "db:push": "pnpm --filter @new-cursor/db db:push"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.6",
    "@dotenvx/dotenvx": "^1.34.0",
    "lefthook": "^1.12.2",
    "turbo": "^2.5.5",
    "typescript": "~5.8.3"
  }
}
